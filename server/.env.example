# ===== Server =====
PORT=3002
NODE_ENV=production

# Public site URL — used for PayPal return/cancel links
SITE_URL=https://en.bixiong.art

# JWT secret for signing auth tokens (use a long random string in production)
JWT_SECRET=change-me-to-a-long-random-string

# SQLite database file (relative to server dir)
DB_PATH=data/app.db

# ===== PayPal =====
# Mode: sandbox (testing) | live (production)
PAYPAL_MODE=sandbox
PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_CLIENT_SECRET=your-paypal-client-secret

# ===== Alipay (支付宝电脑网站支付, 与中文版同款商户) =====
# 应用私钥 / 支付宝公钥：粘贴完整 PEM（含 -----BEGIN/END----- 头尾），多行用 \n 连接
ALIPAY_APP_ID=your-alipay-app-id
ALIPAY_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nyour-app-private-key\n-----END PRIVATE KEY-----
ALIPAY_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\nyour-alipay-public-key\n-----END PUBLIC KEY-----
# 网关：生产 https://openapi.alipay.com/gateway.do  沙箱 https://openapi.alipaydev.com/gateway.do
ALIPAY_GATEWAY=https://openapi.alipay.com/gateway.do
# 异步通知地址（必须公网可访问，支付宝付款成功后回调）：https://你的域名/api/alipay/notify
ALIPAY_NOTIFY_URL=https://en.bixiong.art/api/alipay/notify
ALIPAY_RETURN_URL=https://en.bixiong.art/?payment=success

# ===== SMTP (verification emails) =====
# Leave SMTP_HOST blank to run in DEV mode — verification codes are returned
# in the /api/verify/send response and printed to the server console.
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
SMTP_FROM=PencilBear AI <no-reply@pencilbear.ai>

# ===== Static frontend =====
# Directory to serve the built frontend from. Leave blank to auto-detect ../dist
STATIC_DIR=
